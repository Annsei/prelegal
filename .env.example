# Copy to .env at the repo root. The start scripts forward this file into
# the Docker container.

# Required for the AI chat (/api/chat returns 502 without it).
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Optional — only for local non-Docker dev where the Next dev server (:3000)
# talks to FastAPI (:8000) cross-origin. Leave unset in Docker.
# PRELEGAL_CORS_ORIGINS=http://localhost:3000

# Optional — SQLite file path. Defaults to /data/prelegal.sqlite in Docker.
# PRELEGAL_DB_PATH=./prelegal-dev.sqlite

# Optional — session lifetime in days (default 30; 0 = never expire).
# PRELEGAL_SESSION_TTL_DAYS=30

# Optional — set to 1 to disable login/register/chat rate limits.
# For load testing only; never in production.
# PRELEGAL_RATELIMIT_DISABLED=1
