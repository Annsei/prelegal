{
  "doc_id": "cloud-service-agreement",
  "version": 2,
  "description": "《SaaS 服务协议》（中国法，Prelegal 范本 v1.0）封面页字段清单。字段键与正文 coverpage_link / orderform_link / keyterms_link span 中的变量名逐字一致；AI 对话抽取、手动编辑表单、封面页渲染与正文引用高亮均由本文件驱动。",
  "sections": [
    { "key": "parties", "label": { "zh": "当事方", "en": "Parties" } },
    { "key": "order", "label": { "zh": "商务条款", "en": "Order Terms" } },
    { "key": "keyterms", "label": { "zh": "关键法律条款", "en": "Key Legal Terms" } }
  ],
  "fields": [
    {
      "key": "服务方",
      "section": "parties",
      "type": "string",
      "required": true,
      "label": { "zh": "服务方（公司名）", "en": "Provider (company)" },
      "hint": { "zh": "提供云服务的一方", "en": "The party providing the cloud service" },
      "example": "示例云计算（上海）有限公司"
    },
    {
      "key": "客户",
      "section": "parties",
      "type": "string",
      "required": true,
      "label": { "zh": "客户（公司名）", "en": "Customer (company)" },
      "hint": { "zh": "订阅并使用云服务的一方", "en": "The party subscribing to the service" },
      "example": "示例科技（北京）有限公司"
    },
    {
      "key": "服务方通知地址",
      "section": "parties",
      "type": "string",
      "required": false,
      "label": { "zh": "服务方通知地址", "en": "Provider Notice Address" },
      "hint": { "zh": "第 12.6 条通知条款的送达地址（邮箱或邮寄地址，可选）", "en": "Where notices under §12.6 are sent (optional)" },
      "example": "legal@example-cloud.cn"
    },
    {
      "key": "客户通知地址",
      "section": "parties",
      "type": "string",
      "required": false,
      "label": { "zh": "客户通知地址", "en": "Customer Notice Address" },
      "hint": { "zh": "第 12.6 条通知条款的送达地址（邮箱或邮寄地址，可选）", "en": "Where notices under §12.6 are sent (optional)" },
      "example": "legal@example.com.cn"
    },
    {
      "key": "云服务内容",
      "section": "order",
      "type": "text",
      "required": true,
      "label": { "zh": "云服务内容", "en": "Cloud Service" },
      "hint": { "zh": "所订阅产品/服务的简要描述", "en": "Short description of the subscribed product" },
      "example": "示例数据分析平台（团队版）"
    },
    {
      "key": "订单日期",
      "section": "order",
      "type": "date",
      "required": true,
      "label": { "zh": "订单日期", "en": "Order Date" },
      "hint": { "zh": "ISO 格式（YYYY-MM-DD）", "en": "ISO format (YYYY-MM-DD)" },
      "example": "2026-07-01"
    },
    {
      "key": "订阅期",
      "section": "order",
      "type": "string",
      "required": true,
      "label": { "zh": "订阅期", "en": "Subscription Period" },
      "hint": { "zh": "如 12 个月；期满自动按原期限续期", "en": "e.g. 12 months; auto-renews" },
      "example": "12 个月"
    },
    {
      "key": "不续约通知期",
      "section": "order",
      "type": "string",
      "required": true,
      "label": { "zh": "不续约通知期", "en": "Non-Renewal Notice Period" },
      "hint": { "zh": "订阅期届满前多久须发出不续约书面通知", "en": "Notice window before the period ends" },
      "example": "订阅期届满前 30 日"
    },
    {
      "key": "服务费",
      "section": "order",
      "type": "text",
      "required": true,
      "label": { "zh": "服务费", "en": "Fees" },
      "hint": { "zh": "金额与计费口径（人民币，含税/不含税）", "en": "Amount and pricing basis" },
      "example": "人民币 20,000 元/月（含税）"
    },
    {
      "key": "付款方式",
      "section": "order",
      "type": "string",
      "required": true,
      "label": { "zh": "付款方式", "en": "Payment Process" },
      "hint": { "zh": "付款方式与账期", "en": "Payment method and terms" },
      "example": "按季度预付，收到发票后 30 日内付款"
    },
    {
      "key": "技术支持",
      "section": "order",
      "type": "text",
      "required": false,
      "label": { "zh": "技术支持", "en": "Technical Support" },
      "hint": { "zh": "支持渠道与响应承诺（可选）", "en": "Support channels and commitments (optional)" },
      "example": "工作日 9:00-18:00 邮件与在线工单支持"
    },
    {
      "key": "使用限制",
      "section": "order",
      "type": "text",
      "required": false,
      "label": { "zh": "使用限制", "en": "Use Limitations" },
      "hint": { "zh": "席位数、用量或其他限制（可选）", "en": "Seats, usage, or other limits (optional)" },
      "example": "不超过 50 个用户账号"
    },
    {
      "key": "生效日期",
      "section": "keyterms",
      "type": "date",
      "required": true,
      "label": { "zh": "生效日期", "en": "Effective Date" },
      "hint": { "zh": "ISO 格式（YYYY-MM-DD）", "en": "ISO format (YYYY-MM-DD)" },
      "example": "2026-07-01"
    },
    {
      "key": "争议解决",
      "section": "keyterms",
      "type": "string",
      "required": true,
      "label": { "zh": "争议解决", "en": "Dispute Resolution" },
      "hint": { "zh": "仲裁机构或管辖法院", "en": "Arbitration commission or competent court" },
      "example": "上海仲裁委员会按其仲裁规则进行仲裁"
    },
    {
      "key": "一般责任上限",
      "section": "keyterms",
      "type": "string",
      "required": true,
      "label": { "zh": "一般责任上限", "en": "General Liability Cap" },
      "hint": { "zh": "常见写法：索赔前 12 个月已付服务费总额", "en": "Commonly fees paid in the prior 12 months" },
      "example": "索赔发生前 12 个月内客户实际支付的服务费总额"
    },
    {
      "key": "提高责任上限",
      "section": "keyterms",
      "type": "string",
      "required": false,
      "label": { "zh": "提高责任上限", "en": "Increased Liability Cap" },
      "hint": { "zh": "适用于特别违约情形的更高上限（可选）", "en": "Higher cap for special breaches (optional)" },
      "example": "一般责任上限的 2 倍"
    },
    {
      "key": "特别违约情形",
      "section": "keyterms",
      "type": "text",
      "required": false,
      "label": { "zh": "特别违约情形", "en": "Special Breach Events" },
      "hint": { "zh": "适用提高责任上限的违约类型（可选）", "en": "Breaches subject to the increased cap (optional)" },
      "example": "违反第 10 条保密义务；因服务方原因导致的数据安全事件"
    },
    {
      "key": "不设上限责任",
      "section": "keyterms",
      "type": "text",
      "required": false,
      "label": { "zh": "不设上限责任", "en": "Uncapped Liabilities" },
      "hint": { "zh": "完全不受责任上限约束的责任类型（可选）", "en": "Liabilities outside any cap (optional)" },
      "example": "客户的付款义务；侵犯对方知识产权的责任"
    },
    {
      "key": "服务方赔偿范围",
      "section": "keyterms",
      "type": "text",
      "required": true,
      "label": { "zh": "服务方赔偿范围", "en": "Provider Indemnity Scope" },
      "hint": { "zh": "服务方为客户处理并赔偿的第三方权利主张类型", "en": "Third-party claims Provider handles for Customer" },
      "example": "第三方主张云服务侵犯其知识产权的权利主张"
    },
    {
      "key": "客户赔偿范围",
      "section": "keyterms",
      "type": "text",
      "required": true,
      "label": { "zh": "客户赔偿范围", "en": "Customer Indemnity Scope" },
      "hint": { "zh": "客户为服务方处理并赔偿的第三方权利主张类型", "en": "Third-party claims Customer handles for Provider" },
      "example": "因客户数据或客户违法使用云服务引起的第三方权利主张"
    },
    {
      "key": "数据处理协议",
      "section": "keyterms",
      "type": "string",
      "required": false,
      "label": { "zh": "数据处理协议", "en": "Data Processing Agreement" },
      "hint": { "zh": "是否另行签署个人信息委托处理协议（可选）", "en": "Whether a separate DPA is signed (optional)" },
      "example": "双方另行签署的《个人信息委托处理协议》"
    },
    {
      "key": "附加保证",
      "section": "keyterms",
      "type": "text",
      "required": false,
      "label": { "zh": "附加保证", "en": "Additional Warranties" },
      "hint": { "zh": "标准条款之外的额外保证（可选）", "en": "Warranties beyond the standard terms (optional)" },
      "example": "服务方保证云服务符合双方确认的产品文档"
    }
  ]
}
